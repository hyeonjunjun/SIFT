{
  "expo": {
    "name": "Sift",
    "slug": "sift",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/sift-icon.png",
    "scheme": "sift",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/sift-icon-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF8F1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hkjstudio.sift",
      "usesAppleSignIn": true,
      "buildNumber": "163",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ],
        "com.apple.security.application-groups": [
          "group.com.hkjstudio.sift"
        ]
      },
      "associatedDomains": [
        "applinks:sift-rho.vercel.app"
      ],
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "sift",
              "com.googleusercontent.apps.240781979317-1lblejma2h683dpjr3cmd9gdcosb98h2"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Sift needs access to your photos to extract and summarize content from screenshots and images you select for sifting.",
        "NSCameraUsageDescription": "Sift needs access to your camera to let you take photos of documents or scenes to sift and summarize instantly."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/sift-icon.png",
        "backgroundColor": "#FBF8F1"
      },
      "package": "com.hkjstudio.sift",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1205,
      "allowBackup": false,
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "sift"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sift-rho.vercel.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ],
      "permissions": [
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-share-intent",
        {
          "iosAppGroupIdentifier": "group.com.hkjstudio.sift",
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1
          },
          "android": {
            "disableCreateTask": false
          },
          "appleTeamId": "8DA3BAGA32"
        }
      ],
      "expo-apple-authentication",
      "./plugins/withShareExtensionExclusions.js",
      "./plugins/withNativeSharePopup.js",
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "packagingOptions": {
              "pickFirst": [
                "lib/**/libc++_shared.so"
              ]
            }
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f97e75c-3da1-403c-9e5a-92156c51f400"
      }
    },
    "owner": "hkjstudio"
  }
}
